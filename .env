# ── App Config ───────────────────────────────────────────────
VITE_APP_NAME=KantinKita
VITE_APP_ENV=development

# ── API ──────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Pusher / Laravel Echo ─────────────────────────────────────
VITE_PUSHER_APP_KEY=your-pusher-app-key
VITE_PUSHER_APP_CLUSTER=ap1

# ── Midtrans ─────────────────────────────────────────────────
# Client key saja — JANGAN letakkan Server Key di sini
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
VITE_MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js
